    {
      "id": "PROT-TPLO",
      "name": "TPLO Post-Surgical Rehabilitation",
      "description": "16-week gated rehabilitation protocol for tibial plateau leveling osteotomy recovery",
      "targetConditions": ["TPLO", "CCL rupture", "cranial cruciate ligament", "stifle surgery"],
      "species": "canine",
      "totalWeeks": 16,
      "phases": 4,
      "allowedCategories": ["range_of_motion", "gait_retraining", "strengthening", "balance", "hydrotherapy", "manual_therapy"],
      "exercises": [
        { "name": "Controlled Leash Walk — TPLO Weeks 1 to 2", "code": "TPLO-01", "category": "gait_retraining", "phase": 1, "intensityLevel": "low", "durationSeconds": 300, "reps": null, "sets": null, "contraindicatedConditions": ["non-weight-bearing", "incision_dehiscence"] },
        { "name": "Controlled Leash Walk — TPLO Weeks 3 to 4", "code": "TPLO-02", "category": "gait_retraining", "phase": 1, "intensityLevel": "low", "durationSeconds": 600, "reps": null, "sets": null, "contraindicatedConditions": ["incision_dehiscence"] },
        { "name": "Three-Leg Stand Balance — TPLO Early Phase", "code": "TPLO-03", "category": "balance", "phase": 1, "intensityLevel": "low", "durationSeconds": 30, "reps": 5, "sets": 3, "contraindicatedConditions": ["severe_pain", "non-weight-bearing"] },
        { "name": "Passive Range of Motion (All Joints)", "code": "PROM-01", "category": "range_of_motion", "phase": 1, "intensityLevel": "low", "durationSeconds": 180, "reps": 15, "sets": 2, "contraindicatedConditions": ["acute_fracture"] },
        { "name": "Sit to Stand — TPLO Mid Phase", "code": "TPLO-04", "category": "strengthening", "phase": 2, "intensityLevel": "moderate", "durationSeconds": null, "reps": 10, "sets": 3, "contraindicatedConditions": ["severe_pain", "non-weight-bearing"] },
        { "name": "UWTM Gait Training — TPLO Early to Mid Phase", "code": "TPLO-05", "category": "hydrotherapy", "phase": 2, "intensityLevel": "moderate", "durationSeconds": 600, "reps": null, "sets": null, "contraindicatedConditions": ["open_wound", "cardiac_disease_uncleared"] },
        { "name": "Cavaletti Walking — TPLO Mid Phase", "code": "TPLO-06", "category": "gait_retraining", "phase": 2, "intensityLevel": "moderate", "durationSeconds": 300, "reps": null, "sets": 3, "contraindicatedConditions": ["severe_lameness"] },
        { "name": "Balance Disc Work — TPLO Mid Phase", "code": "TPLO-07", "category": "balance", "phase": 3, "intensityLevel": "moderate", "durationSeconds": 60, "reps": null, "sets": 3, "contraindicatedConditions": ["neurologic_deficit"] },
        { "name": "Therapeutic Swimming — TPLO Late Phase", "code": "TPLO-08", "category": "hydrotherapy", "phase": 3, "intensityLevel": "moderate", "durationSeconds": 900, "reps": null, "sets": null, "contraindicatedConditions": ["open_wound", "cardiac_disease_uncleared"] },
        { "name": "Stair Climbing — TPLO Late Phase (Vet Clearance Required)", "code": "TPLO-09", "category": "strengthening", "phase": 4, "intensityLevel": "high", "durationSeconds": null, "reps": 10, "sets": 2, "contraindicatedConditions": ["chondrodystrophic_breed", "severe_pain"] },
        { "name": "Return to Controlled Trot — TPLO Late Phase", "code": "TPLO-10", "category": "gait_retraining", "phase": 4, "intensityLevel": "high", "durationSeconds": 600, "reps": null, "sets": null, "contraindicatedConditions": ["lameness_grade_3_plus"] }
      ]
    },
