# ============================================
# K9 Rehab Pro - Backend Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit your real .env file to git!
# ============================================

# Server
PORT=3000
NODE_ENV=development

# Frontend URL (for CORS)
# Local: http://localhost:3001
# Render: https://k9-rehab-pro.onrender.com
CORS_ORIGIN=http://localhost:3001

# JWT Authentication
# Generate a secret with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Must be at least 32 characters
JWT_SECRET=REPLACE_WITH_GENERATED_SECRET
JWT_EXPIRES_IN=24h

# Anthropic API Key (for VetAI clinical assistant)
# Get yours at: https://console.anthropic.com/
# VetAI will be disabled if this is not set
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Hugging Face API Token (for AI-generated exercise storyboard images)
# Get a free token at: https://huggingface.co/settings/tokens
# Images will use Dog.CEO breed photos as fallback if not set
HF_TOKEN=your-huggingface-token-here

# Database Provider
# "sqlite" (default) — file-based, zero config
# "supabase" — local Docker or hosted Supabase
DB_PROVIDER=sqlite

# Database path (optional — for Render persistent disk)
# DB_PATH=/var/data/database.db

# Supabase (only needed when DB_PROVIDER=supabase)
# Local: run "supabase start" then copy the printed values
# SUPABASE_URL=http://127.0.0.1:54321
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
